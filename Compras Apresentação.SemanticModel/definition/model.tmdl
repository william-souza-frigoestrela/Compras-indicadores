annotation PBI_ProTooling = ["DevMode"]

ref table DCEVPB_SOLICITACAOTEMPOAPROVACAO
ref table dCalendario
ref table Medidas
ref table dEmpresa
ref table dPrioridade
ref table dCategoria
ref table DCEVPBI_PEDIDOPRAZOPAGAMENTO
ref table 'Segmento visualização'
ref table dFornecedores
ref table 'Spend CY / Itens CY'
ref table 'Spend LY / Itens LY'
