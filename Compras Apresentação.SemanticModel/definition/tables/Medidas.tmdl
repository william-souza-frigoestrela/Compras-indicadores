	measure 'Resultado Operacional Mensal' =
			
			SUMX(
			    VALUES(DCEVPB_SOLICITACAOTEMPOAPROVACAO[SEQPRODUTO]),
			
			    VAR ProdutoAtual =
			        MAX(DCEVPB_SOLICITACAOTEMPOAPROVACAO[SEQPRODUTO])
			
			    VAR UltimaDataMes =
			        CALCULATE(
			            MAX(DCEVPB_SOLICITACAOTEMPOAPROVACAO[DTAEMISSAO])
			        )
			
			    VAR DataAnterior =
			        CALCULATE(
			            MAX(DCEVPB_SOLICITACAOTEMPOAPROVACAO[DTAEMISSAO]),
			            REMOVEFILTERS(dCalendario),
			            DCEVPB_SOLICITACAOTEMPOAPROVACAO[SEQPRODUTO] = ProdutoAtual,
			            DCEVPB_SOLICITACAOTEMPOAPROVACAO[DTAEMISSAO] < UltimaDataMes
			        )
			
			    VAR PrecoAtual =
			        CALCULATE(
			            MAX(DCEVPB_SOLICITACAOTEMPOAPROVACAO[VLRUNITARIO]),
			            DCEVPB_SOLICITACAOTEMPOAPROVACAO[SEQPRODUTO] = ProdutoAtual,
			            DCEVPB_SOLICITACAOTEMPOAPROVACAO[DTAEMISSAO] = UltimaDataMes
			        )
			
			    VAR PrecoAnterior =
			        CALCULATE(
			            MAX(DCEVPB_SOLICITACAOTEMPOAPROVACAO[VLRUNITARIO]),
			            REMOVEFILTERS(dCalendario),
			            DCEVPB_SOLICITACAOTEMPOAPROVACAO[SEQPRODUTO] = ProdutoAtual,
			            DCEVPB_SOLICITACAOTEMPOAPROVACAO[DTAEMISSAO] = DataAnterior
			        )
			
			    VAR QuantidadeMes =
			        CALCULATE(
			            SUM(DCEVPB_SOLICITACAOTEMPOAPROVACAO[QUANTIDADE]),
			            DCEVPB_SOLICITACAOTEMPOAPROVACAO[SEQPRODUTO] = ProdutoAtual,
			            DCEVPB_SOLICITACAOTEMPOAPROVACAO[DTAEMISSAO] = UltimaDataMes
			        )
			
			    RETURN
			        COALESCE(
			            (PrecoAnterior - PrecoAtual) * QuantidadeMes,
			            0
			        )
			)
