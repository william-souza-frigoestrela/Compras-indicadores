	measure 'PMP Ponderado CY' =
			
			VAR Numerador =
			    CALCULATE(
			        SUMX(
			            DCEVPBI_PEDIDOPRAZOPAGAMENTO,
			            DCEVPBI_PEDIDOPRAZOPAGAMENTO[VLRPEDIDO]
			                * DCEVPBI_PEDIDOPRAZOPAGAMENTO[PMP]
			        )
			    )
			VAR Denominador =
			    CALCULATE(
			        SUM(DCEVPBI_PEDIDOPRAZOPAGAMENTO[VLRPEDIDO])
			    )
			RETURN
			    DIVIDE(Numerador, Denominador, BLANK())
		formatString: 0.00
		lineageTag: f439cd39-1f1a-4791-889d-ba4923b624a5

	measure 'PMP Ponderado LY' =
			
			CALCULATE(
			    [PMP Ponderado CY],
			    SAMEPERIODLASTYEAR(dCalendario[Date])
			)
		formatString: 0.00
		lineageTag: 2e73c629-d072-4c5f-93ce-328b20315c8e

	measure 'Var % PMP LY' =
			
