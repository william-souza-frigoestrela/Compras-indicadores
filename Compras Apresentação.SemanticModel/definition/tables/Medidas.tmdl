	measure 'Resultado Operacional Mensalizado' = ```
			
			-- 1. Captura o último dia do mês corrente no eixo do gráfico
			VAR UltimoDiaDoMes = MAX(DCalendario[Date]) 
			
			RETURN
			    CALCULATE(
			        [Resultado operacional CY], -- Sua medida original do Card, sem alterar nenhuma linha
			        FILTER(
			            ALLSELECTED(DCalendario), -- Mantém os filtros dos seus segmentadores da tela
			            DCalendario[Date] <= UltimoDiaDoMes -- Permite que a medida olhe para trás para achar o histórico anterior
			        )
			    )
