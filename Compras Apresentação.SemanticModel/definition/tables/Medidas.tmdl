	measure 'Qtd Itens Saving' = ```
			
			SUMX(
			    VALUES(DCEVPB_SOLICITACAOTEMPOAPROVACAO[SEQPRODUTO]),
			    VAR PrecoAtual = 
			        DIVIDE(
			            SUMX(
			                DCEVPB_SOLICITACAOTEMPOAPROVACAO,
			                DCEVPB_SOLICITACAOTEMPOAPROVACAO[VLRUNITARIO] 
			                    * DCEVPB_SOLICITACAOTEMPOAPROVACAO[QUANTIDADE]
