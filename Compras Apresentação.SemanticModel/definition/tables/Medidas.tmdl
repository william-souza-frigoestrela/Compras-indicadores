	measure '% Variação Label spend' =
			
			VAR vVariacao = [Var % Spend LY]
			RETURN
			    FORMAT(vVariacao, "  ⮝ +0.0% ;  ⮟ -0.0% ;  → 0%")
		lineageTag: eaba1ce2-a6fe-4121-a9be-dceb617d5c4d

	measure 'Variação Label delta gastos' = ```
			
			VAR vVariacao = [Delta Gastos]
			
			-- Realiza a divisão matemática direto na variável (Força a escala de milhões)
			VAR vVariacaoMilhoes = vVariacao / 1000000 
			
			RETURN
			    SWITCH(
			        TRUE(),
			        -- Se for Positivo
			        vVariacao > 0, "  ⮝ +" & FORMAT( vVariacaoMilhoes, "#,##0.0" ) & " Mi",
			        
			        -- Se for Negativo (Multiplicamos por -1 para o sinal de menos não duplicar)
			        vVariacao < 0, "  ⮟ -" & FORMAT( vVariacaoMilhoes * -1, "#,##0.0" ) & " Mi",
			        
			        -- Se for Zero
			        "  → R$ 0,0 Mi"
			    )
			```
		lineageTag: b1bd6fe9-c2a0-45be-94e0-245313f46615

	measure 'Spend CY - Var LY' = ```
			
			FORMAT([Spend CY], "R$ #,##0,,\M") 
			    & "  ·  " 
			    & FORMAT([% Variação Label spend], "+0%;-0%;0%")
			```
