	measure 'Delta Preco Unitario' =
			
			VAR PrecoAtual = [Preco Atual]
			VAR PrecoAnterior = [Preco Ultima Compra]
			RETURN
			IF(
			    ISBLANK(PrecoAnterior),
			    BLANK(),
			    PrecoAnterior - PrecoAtual
