			                DCEVPB_SOLICITACAOTEMPOAPROVACAO[VLRUNITARIO] 
			                    * DCEVPB_SOLICITACAOTEMPOAPROVACAO[QUANTIDADE]
			            ),
			            SUM(DCEVPB_SOLICITACAOTEMPOAPROVACAO[QUANTIDADE])
			        )
			    VAR PrecoAnterior = [Preco Ultima Compra]
			    RETURN
			    IF(
			        NOT ISBLANK(PrecoAnterior) 
