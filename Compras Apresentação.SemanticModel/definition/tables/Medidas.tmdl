	measure ultimaCompra =
			
			IF(ISINSCOPE(DCEVPB_SOLICITACAOTEMPOAPROVACAO[SEQPRODUTO]),
			MAX(DCEVPB_SOLICITACAOTEMPOAPROVACAO[DTAEMISSAO]),BLANK())
		formatString: General Date
		lineageTag: 428e5834-21c5-450d-b832-551bb3be2db5

	measure 'Data Ultima Compra' =
			
			VAR ProdutoAtual = MAX(DCEVPB_SOLICITACAOTEMPOAPROVACAO[SEQPRODUTO])
			VAR DataEmissaoAtual = MAX(DCEVPB_SOLICITACAOTEMPOAPROVACAO[DTAEMISSAO])
			RETURN
			CALCULATE(
			    MAX(DCEVPB_SOLICITACAOTEMPOAPROVACAO[DTAEMISSAO]),
			    FILTER(
			        ALL(DCEVPB_SOLICITACAOTEMPOAPROVACAO),
			        DCEVPB_SOLICITACAOTEMPOAPROVACAO[SEQPRODUTO] = ProdutoAtual
			            && DCEVPB_SOLICITACAOTEMPOAPROVACAO[DTAEMISSAO] < DataEmissaoAtual
			    )
			)
		formatString: General Date
		lineageTag: 65155f31-e20b-4b7a-a2db-c5aeae408bd9

	measure 'Preco Ultima Compra' = ```
			
			VAR DataAtual = MAX(DCEVPB_SOLICITACAOTEMPOAPROVACAO[DTAEMISSAO])
			VAR ProdutoAtual = SELECTEDVALUE(DCEVPB_SOLICITACAOTEMPOAPROVACAO[SEQPRODUTO])
			
			-- 1. Encontra a data da última compra antes da data atual para este produto
			VAR DataUltimaCompra = 
			    CALCULATE(
			        MAX(DCEVPB_SOLICITACAOTEMPOAPROVACAO[DTAEMISSAO]),
			        REMOVEFILTERS(DCEVPB_SOLICITACAOTEMPOAPROVACAO[DTAEMISSAO]), -- Limpa a data atual
			        DCEVPB_SOLICITACAOTEMPOAPROVACAO[DTAEMISSAO] < DataAtual,
			        DCEVPB_SOLICITACAOTEMPOAPROVACAO[SEQPRODUTO] = ProdutoAtual
			    )
			
			-- 2. Calcula o preço médio ponderado especificamente na data dessa última compra
			VAR PrecoPonderadoAnterior = 
			    CALCULATE(
			        DIVIDE(
			            SUMX(
			                DCEVPB_SOLICITACAOTEMPOAPROVACAO,
			                DCEVPB_SOLICITACAOTEMPOAPROVACAO[VLRUNITARIO] * DCEVPB_SOLICITACAOTEMPOAPROVACAO[QUANTIDADE]
			            ),
			            SUM(DCEVPB_SOLICITACAOTEMPOAPROVACAO[QUANTIDADE])
			        ),
			        REMOVEFILTERS(DCEVPB_SOLICITACAOTEMPOAPROVACAO[DTAEMISSAO]),
			        DCEVPB_SOLICITACAOTEMPOAPROVACAO[DTAEMISSAO] = DataUltimaCompra,
			        DCEVPB_SOLICITACAOTEMPOAPROVACAO[SEQPRODUTO] = ProdutoAtual
			    )
			
			RETURN
			    PrecoPonderadoAnterior
			```
		lineageTag: 376befdd-07d3-4b16-be34-bc854c4fc248

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Var % Preco Ultima Compra' =
			
			VAR PrecoAtual = AVERAGE(DCEVPB_SOLICITACAOTEMPOAPROVACAO[VLRUNITARIO])
			VAR PrecoAnterior = [Preco Ultima Compra]
			RETURN
			DIVIDE(
			    PrecoAtual - PrecoAnterior,
			    PrecoAnterior,
			    BLANK()
			)
		lineageTag: ce9f4988-20bc-4fe5-8222-bbbf0e0d0cce

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Status Variacao Preco' =
			
			VAR Variacao = [Var % Preco Ultima Compra]
			RETURN
			SWITCH(
			    TRUE(),
			    ISBLANK(Variacao),        "Primeira compra",
			    Variacao > 0.00,          "Penalty",
			    Variacao< 0.00,         "Saving",
			                         "Net"
			)
		lineageTag: 9f005b73-363e-4da7-b5e9-dba5bcf20858

	measure 'Icone Info' = "ⓘ"
		lineageTag: df1e97d1-d8f4-42c5-a229-37c5549f23c1

	measure 'Saving Total' = ```
			
			SUMX(
			    VALUES(DCEVPB_SOLICITACAOTEMPOAPROVACAO[SEQPRODUTO]),
			    VAR PrecoAtualPonderado = 
			        DIVIDE(
			            SUMX(
			                DCEVPB_SOLICITACAOTEMPOAPROVACAO,
			                DCEVPB_SOLICITACAOTEMPOAPROVACAO[VLRUNITARIO] * DCEVPB_SOLICITACAOTEMPOAPROVACAO[QUANTIDADE]
			            ),
			            SUM(DCEVPB_SOLICITACAOTEMPOAPROVACAO[QUANTIDADE])
			        )
			    VAR PrecoAnterior = [Preco Ultima Compra]
			    VAR QtdAtual = SUM(DCEVPB_SOLICITACAOTEMPOAPROVACAO[QUANTIDADE])
			    VAR DeltaPreco = PrecoAnterior - PrecoAtualPonderado
			    
			    RETURN
			        IF(
			            NOT(ISBLANK(PrecoAnterior)) && DeltaPreco > 0,
			            DeltaPreco * QtdAtual,
			            0
			        )
			)
			```
		lineageTag: cd981126-72f5-47c8-9617-c9d2e2bb9383

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Penalty Total' = ```
			
			SUMX(
			    VALUES(DCEVPB_SOLICITACAOTEMPOAPROVACAO[SEQPRODUTO]),
			    VAR PrecoAtualPonderado = 
			        DIVIDE(
			            SUMX(
			                DCEVPB_SOLICITACAOTEMPOAPROVACAO,
			                DCEVPB_SOLICITACAOTEMPOAPROVACAO[VLRUNITARIO] * DCEVPB_SOLICITACAOTEMPOAPROVACAO[QUANTIDADE]
			            ),
			            SUM(DCEVPB_SOLICITACAOTEMPOAPROVACAO[QUANTIDADE])
			        )
			    VAR PrecoAnterior = [Preco Ultima Compra]
			    VAR QtdAtual = SUM(DCEVPB_SOLICITACAOTEMPOAPROVACAO[QUANTIDADE])
			    VAR DeltaPreco = PrecoAnterior - PrecoAtualPonderado
			    
			    RETURN
			        IF(
			            NOT(ISBLANK(PrecoAnterior)) && DeltaPreco < 0,
			            ABS(DeltaPreco) * QtdAtual, -- O ABS transforma o valor negativo em positivo para exibição
			            0
			        )
			)
			```
		lineageTag: 6cfd749b-de37-4996-a867-8ae3075846c0

		annotation PBI_FormatHint = {"isGeneralNumber":true}

