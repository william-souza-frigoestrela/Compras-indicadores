	measure 'Resultado operacional dinamico CY' = ```
			
			-- 1. Cria a lista de produtos respeitando o filtro da linha da matriz (Fornecedor, Empresa ou Categoria)
			VAR ProdutosVisiveis = 
			    CALCULATETABLE(
			        VALUES(DCEVPB_SOLICITACAOTEMPOAPROVACAO[SEQPRODUTO]),
			        ALLSELECTED(DCEVPB_SOLICITACAOTEMPOAPROVACAO[SEQPRODUTO])
			    )
			RETURN
			SUMX(
			    ProdutosVisiveis,
			    VAR ProdutoAtual = DCEVPB_SOLICITACAOTEMPOAPROVACAO[SEQPRODUTO]
			    
			    -- 2. Encontra a última data liberando apenas os filtros de data e produto, preservando o segmento da matriz
			    VAR UltimaData = 
			        CALCULATE(
			            MAX(DCEVPB_SOLICITACAOTEMPOAPROVACAO[DTAEMISSAO]),
			            ALLSELECTED(DCEVPB_SOLICITACAOTEMPOAPROVACAO[DTAEMISSAO]),
			            DCEVPB_SOLICITACAOTEMPOAPROVACAO[SEQPRODUTO] = ProdutoAtual
			        )
			        
			    -- 3. Preço Atual
			    VAR PrecoAtual = 
			        CALCULATE(
			            AVERAGE(DCEVPB_SOLICITACAOTEMPOAPROVACAO[VLRUNITARIO]),
			            ALLSELECTED(DCEVPB_SOLICITACAOTEMPOAPROVACAO[DTAEMISSAO]),
			            DCEVPB_SOLICITACAOTEMPOAPROVACAO[SEQPRODUTO] = ProdutoAtual,
			            DCEVPB_SOLICITACAOTEMPOAPROVACAO[DTAEMISSAO] = UltimaData
			        )
			        
			    -- 4. Data Anterior
			    VAR DataAnterior = 
			        CALCULATE(
			            MAX(DCEVPB_SOLICITACAOTEMPOAPROVACAO[DTAEMISSAO]),
			            ALLSELECTED(DCEVPB_SOLICITACAOTEMPOAPROVACAO[DTAEMISSAO]),
			            DCEVPB_SOLICITACAOTEMPOAPROVACAO[SEQPRODUTO] = ProdutoAtual,
			            DCEVPB_SOLICITACAOTEMPOAPROVACAO[DTAEMISSAO] < UltimaData
			        )
			        
			    -- 5. Preço Anterior
			    VAR PrecoAnterior = 
			        CALCULATE(
			            AVERAGE(DCEVPB_SOLICITACAOTEMPOAPROVACAO[VLRUNITARIO]),
			            ALLSELECTED(DCEVPB_SOLICITACAOTEMPOAPROVACAO[DTAEMISSAO]),
			            DCEVPB_SOLICITACAOTEMPOAPROVACAO[SEQPRODUTO] = ProdutoAtual,
			            DCEVPB_SOLICITACAOTEMPOAPROVACAO[DTAEMISSAO] = DataAnterior
			        )
			        
			    -- 6. Quantidade
			    VAR Quantidade = 
			        CALCULATE(
			            SUM(DCEVPB_SOLICITACAOTEMPOAPROVACAO[QUANTIDADE]),
			            ALLSELECTED(DCEVPB_SOLICITACAOTEMPOAPROVACAO[DTAEMISSAO]),
			            DCEVPB_SOLICITACAOTEMPOAPROVACAO[SEQPRODUTO] = ProdutoAtual,
			            DCEVPB_SOLICITACAOTEMPOAPROVACAO[DTAEMISSAO] = UltimaData
			        )
			        
			    VAR DeltaUnitario = 
			        IF(
			            NOT ISBLANK(PrecoAnterior),
			            PrecoAnterior - PrecoAtual,
			            BLANK()
			        )
			        
			    RETURN
			    IF(
			        NOT ISBLANK(DeltaUnitario) && NOT ISBLANK(Quantidade),
			        DeltaUnitario * Quantidade,
			        BLANK()
			    )
			)
			```
		formatString: "R$"\ #,0.00;-"R$"\ #,0.00;"R$"\ #,0.00
		lineageTag: 2b816645-445b-4dba-adef-120fffc3f0a0

