			not dClusters[CLUSTERS] in {"MATERIA PRIMA Animais"
			,"ANIMAIS"
			,"ALIMENTOS"
			,"PATRIMONIO Agropecuário"
			,"MRO Agropecuário"
			,"MDI Insumo Agropecuário"
			}
			)*/
			
