			VAR MaiorVariacao = 
			    MAXX(
			        Bottom10Empresas,
			        ABS(CALCULATE([Var % PMP LY]))
			    )
			RETURN
			IF(ABS([Var % PMP LY]) = MaiorVariacao, 1, 0)
