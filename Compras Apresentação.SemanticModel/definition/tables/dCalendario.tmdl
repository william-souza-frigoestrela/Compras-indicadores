	partition dCalendario = calculated
		mode: import
		source =
				
				--VAR vAnoMin = YEAR(MIN(DCEVPB_SOLICITACAOTEMPOAPROVACAO[DTASOLICITACAO]))
				VAR vAnoMin = YEAR(DATE(2025,01,01))
				VAR vAnoMax = YEAR(MAX(DCEVPB_SOLICITACAOTEMPOAPROVACAO[DTASOLICITACAO]))
				VAR vMesMax = MONTH(MAX(DCEVPB_SOLICITACAOTEMPOAPROVACAO[DTASOLICITACAO]))
				var vDiaMax = DAY(MAX(DCEVPB_SOLICITACAOTEMPOAPROVACAO[DTASOLICITACAO]))
				VAR vDataInicial = DATE(vAnoMin, 01, 01)
				VAR vDataFinal = DATE(vAnoMax, vMesMax, vDiaMax)
				RETURN
				ADDCOLUMNS(
				    CALENDAR(vDataInicial, vDataFinal),
				    "Data" , IF(YEAR([Date])=YEAR(TODAY()) && MONTH([Date])=MONTH(TODAY()) && DAY([Date]) = DAY(TODAY()), "Hoje", FORMAT ( [Date],"dd/mm/yyyy")),
				    "Ano2", YEAR([Date]),
				    "Ano" , if (YEAR ( [Date] )= YEAR(TODAY()),"Ano atual",FORMAT([Date],"yyyy")),
				    "Anomês nome", FORMAT ( [Date], "mmm/yy"),
				    "Anomês" , FORMAT([Date],"yyyy/mm"),
				    "Trim num" , QUARTER([Date]),
				    "Trim nome", FORMAT ([Date], "\Qq" ),
				    "Mês num" , MONTH ( [Date] ),
				    "Mês nome", IF(YEAR([Date])=YEAR(TODAY()) && MONTH([Date])=MONTH(TODAY()), "Mês atual", FORMAT ( [Date],"mmmm")),
				    "Mês abreviado", FORMAT ( [Date], "mmm" ),
				    "Dia" , DAY([Date]),
				    "Dia da semana",WEEKDAY([Date],2),
				    "Dia da semana nome", left(FORMAT ([Date],"dddd"),3),
				    "Semana num",WEEKDAY([Date]),
				    "Dia de trabalho", IF(WEEKDAY([Date],2)=1||WEEKDAY([Date],2)=7,"N","S"),
				    "Ano atual" , IF(YEAR([Date])=YEAR(TODAY()),"S","N"),
				    "Mês atual" , IF(YEAR([Date])=YEAR(TODAY()) && MONTH([Date])=MONTH(TODAY()),"S","N"),
				    "Dia atual" , IF(YEAR([Date])=YEAR(TODAY()) && MONTH([Date])=MONTH(TODAY()) && DAY([Date])=DAY(TODAY()),"S","N"),
				    "Ano móvel" , DATEDIFF(TODAY(),[Date],YEAR),
				    "Trim. móvel",DATEDIFF(TODAY(),[Date],QUARTER),
				    "Mês móvel",DATEDIFF(TODAY(),[Date],MONTH),
				    "Semana móvel",DATEDIFF(TODAY(),[Date],WEEK),
				    "Dia movel",DATEDIFF(TODAY(),[Date],DAY)
				)

	annotation PBI_Id = 7e9024cce955415b901d1cb9a381d910

